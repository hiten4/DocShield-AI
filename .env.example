# App
APP_ENV=dev
JWT_SECRET=change-me-to-a-long-random-hex-string
JWT_ALG=HS256
JWT_TTL_MIN=15
UPLOAD_MAX_MB=25

# Postgres
# App connects as befree_app (NOT befree): the postgres image makes befree a
# SUPERUSER, and superusers bypass row-level security — killing tenant isolation.
# The role is created by backend/db/init/01_app_role.sql on first DB init.
POSTGRES_DSN=postgresql+psycopg://befree_app:befree_app@postgres:5432/befree

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=chunks
VECTOR_DIM=1024

# Redis
REDIS_URL=redis://redis:6379/0

# Models
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base
DEVICE=cpu

# LLM (LiteLLM)
LITELLM_MODEL=groq/llama-3.3-70b-versatile
GROQ_API_KEY=
GEMINI_API_KEY=
LLM_MAX_TOKENS=1024
CONTEXT_TOKEN_BUDGET=4000
TOP_K_PARENTS=5
TOP_K_VECTOR=30

# Injection classifier
INJECTION_MODEL=protectai/deberta-v3-base-prompt-injection
INJECTION_THRESHOLD=0.7

# ClamAV
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# Chunking
PARA_CHUNK_TOKENS=512
PARA_CHUNK_OVERLAP=64
TABLE_ROWS_PER_CHUNK=3
TABLE_SMALL_THRESHOLD=4
LIST_ITEMS_PER_CHUNK=4

# PII vault — REQUIRED for ingestion of documents containing PII.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PII_VAULT_KEY=
# Set false to keep mask tokens in query answers instead of unmasking.
PII_UNMASK_ON_QUERY=true
